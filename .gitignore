# Commit the small, non-PII processed artefacts so the Streamlit Cloud
# deploy works without needing raw files.
!data/source/
data/source/*
!data/source/Project\ Pharma.kmz
# DO NOT commit the raw NPRA PDF — it contains preceptor names & emails.
# We only commit the processed output where PII is already stripped.
!data/pharmacies_npra_geocoded.csv
!data/pharmacies_pmg_geocoded.csv
!data/source/PMG\ outlets\ (Pharmacy,\ Medical\ &\ Dental\ Clinics).xlsx
!data/worldpop_per_district.csv
!data/districts_my_adm2.geojson
!data/geocode_cache.json
!data/geocode_cache_google.json
!data/worldpop_per_mukim.csv
!data/worldpop_per_zone.csv
!data/mukim_my_adm3.geojson
!data/kkm_zones.geojson

