# Copy this file to `.env` in the same directory and fill in your real key.
# `.env` is git-ignored — it MUST NOT be committed.

# Required for the Google geocoder path (used by geocode_npra.py and app.py).
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
# Enable: "Geocoding API" for your project.
# Restrict: HTTP-referrer or IP-based restriction is strongly recommended.
GOOGLE_MAPS_API_KEY=your-api-key-here
